{
    "name": "mcp-ai-agent-guidelines",
    "version": "0.17.0",
    "description": "MCP server exposing public instruction workflows as tools, backed by hidden AI agent skills for requirements, orchestration, quality, research, evaluation, governance, resilience, and physics-inspired analysis",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "npm run build && node dist/index.js",
        "dev": "tsc --watch",
        "prepare": "if [ -d .git ]; then lefthook install; else echo 'Skipping lefthook install (no Git repository)'; fi",
        "pretest": "npm run build",
        "test": "vitest run",
        "test:jest": "npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --runInBand",
        "test:simulations": "vitest run src/tests/simulations/**/*.test.ts",
        "test:coverage": "vitest run --coverage",
        "test:mcp:ts": "vitest run src/tests/tools/workspace-tools.test.ts src/tests/mock/mcp/mock-jsonrpc.test.ts",
        "pretest:mcp:sdk": "npm run build",
        "test:mcp:sdk": "vitest run src/tests/mcp/sdk-compatibility-lane.test.ts",
        "pretest:mcp:py": "npm run build",
        "test:mcp:py": "python3 -m unittest scripts.test_mcp_smoke",
        "pretest:mcp:py:inspector": "npm run build",
        "test:mcp:py:inspector": "python3 -m unittest scripts.test_mcp_smoke_inspector",
        "test:mcp:smoke": "npm run test:mcp:ts && npm run test:mcp:sdk && npm run test:mcp:py",
        "test:mcp:smoke:inspector": "npm run test:mcp:ts && npm run test:mcp:sdk && npm run test:mcp:py:inspector",
        "test:toon": "vitest run src/tests/runtime/toon-architecture-contracts.test.ts",
        "toon:markdown": "npm run build && node scripts/toon-to-markdown.mjs",
        "demo:toon": "npm run build && node dist/toon-demo.js",
        "lint": "biome lint --diagnostic-level=error src/",
        "lint:fix": "biome lint --write src/",
        "format": "biome format src/",
        "format:fix": "biome format --write src/",
        "check": "biome check --diagnostic-level=error src/",
        "check:fix": "biome check --write src/",
        "check:workflow-docs": "vitest run src/tests/workflows/workflow-doc-contract.test.ts",
        "type-check": "tsc --noEmit",
        "audit:packages:check": "python3 scripts/check_package_skill_mapping.py",
        "audit:deps:check": "python3 scripts/audit-dependency-usage.py",
        "audit:migration:check": "python3 scripts/audit-migration-state.py --output-dir audit",
        "audit:coverage:hotspots": "python3 scripts/audit-coverage-hotspots.py",
        "audit:biome": "python3 scripts/audit-biome-issues.py",
        "audit:biome:unused": "python3 scripts/audit-biome-issues.py --unused-only",
        "audit:type-safety": "python3 scripts/audit-type-safety.py",
        "quality": "python3 scripts/verify_matrix.py && python3 -m unittest scripts.test_generate_tool_definitions && npm run type-check && npm run check:workflow-docs && npm run check && python3 scripts/audit-dependency-usage.py",
        "generate:tool-definitions": "python3 scripts/generate-tool-definitions.py",
        "generate:skill-graph": "python3 scripts/visualize_skill_graph.py",
        "generate:test-mirrors": "python3 scripts/generate-test-mirrors.py",
        "generate:test-mirrors:dry": "python3 scripts/generate-test-mirrors.py --dry-run",
        "generate:todo-lists": "python3 scripts/generate-todo-lists.py",
        "generate:todo-lists:dry": "python3 scripts/generate-todo-lists.py --dry-run",
        "generate:skill-docs": "node scripts/generate-skill-docs.mjs",
        "generate:all": "python3 scripts/generate-tool-definitions.py && python3 scripts/visualize_skill_graph.py && node scripts/generate-skill-docs.mjs",
        "check:generated": "npm run generate:all && git diff --exit-code src/generated/ docs/architecture/03-skill-graph.md",
        "docs:dev": "astro dev --root docs",
        "docs:build": "astro build --root docs",
        "docs:preview": "astro preview --root docs"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "ai-agent",
        "guidelines",
        "skills",
        "tools",
        "prompts",
        "best-practices",
        "orchestration",
        "architecture",
        "governance"
    ],
    "author": "Anselmoo",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Anselmoo/mcp-ai-agent-guidelines.git"
    },
    "homepage": "https://github.com/Anselmoo/mcp-ai-agent-guidelines#readme",
    "bugs": {
        "url": "https://github.com/Anselmoo/mcp-ai-agent-guidelines/issues"
    },
    "bin": {
        "mcp-ai-agent-guidelines": "dist/index.js",
        "mcp-cli": "dist/cli-main.js",
        "toon-demo": "dist/toon-demo.js"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=22.7.5",
        "npm": ">=10.0.0"
    },
    "overrides": {
        "picomatch": "^4.0.4"
    },
    "devDependencies": {
        "@astrojs/starlight": "^0.34.0",
        "@biomejs/biome": "2.4.14",
        "@modelcontextprotocol/inspector": "^0.21.1",
        "@types/d3": "^7.4.3",
        "@types/inquirer": "^9.0.9",
        "@types/jsdom": "^28.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.0.2",
        "@vitest/coverage-v8": "^4.0.0",
        "astro": "^5.7.0",
        "astro-mermaid": "^2.0.1",
        "d3": "^7.9.0",
        "inquirer": "^13.3.2",
        "jest": "^30.3.0",
        "lefthook": "^2.1.5",
        "lucide-astro": "^0.556.0",
        "mermaid": "^11.14.0",
        "rehype-mathjax": "^7.1.0",
        "remark-math": "^6.0.0",
        "sharp": "^0.34.0",
        "typescript": "^6.0.0",
        "vitest": "^4.0.0"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^1.0.0",
        "@ai-sdk/openai": "^1.0.0",
        "@inquirer/prompts": "^7.5.2",
        "@modelcontextprotocol/sdk": "^1.17.1",
        "@noble/hashes": "^2.0.1",
        "@paralleldrive/cuid2": "^2.2.2",
        "@svgdotjs/svg.js": "^3.2.4",
        "@toon-format/toon": "^2.1.0",
        "ai": "^6.0.145",
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "d3-path": "^3.1.0",
        "d3-shape": "^3.2.0",
        "devalue": "^5.1.1",
        "execa": "^9.5.2",
        "fast-glob": "^3.3.3",
        "fflate": "^0.8.2",
        "gpt-tokenizer": "^2.9.0",
        "graphology": "^0.26.0",
        "graphology-dag": "^0.4.1",
        "graphology-shortest-path": "^2.1.0",
        "graphology-traversal": "^0.3.1",
        "gray-matter": "^4.0.3",
        "json-schema-to-ts": "^3.1.1",
        "jsonpath-plus": "^10.3.0",
        "mathjs": "^15.2.0",
        "neverthrow": "^8.2.0",
        "ohash": "^2.0.11",
        "ora": "^8.2.0",
        "p-queue": "^9.1.1",
        "p-retry": "^8.0.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "remeda": "^2.21.0",
        "roughjs": "^4.6.6",
        "satori": "^0.12.1",
        "simple-statistics": "^7.8.9",
        "smol-toml": "^1.6.1",
        "ts-pattern": "^5.7.0",
        "uint8array-extras": "^1.4.0",
        "xstate": "^5.30.0",
        "yaml": "^2.7.1",
        "zod": "^3.25.76",
        "zod-to-json-schema": "^3.24.1",
        "zod-validation-error": "^3.5.0",
        "zx": "^8.5.0"
    }
}
